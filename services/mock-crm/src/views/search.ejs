<!DOCTYPE html>
<html lang="en">
<head><title>Customer Search — FirstBank CRM</title><%- include('_head') %></head>
<body>
  <%- include('_nav', { user, active: 'search' }) %>
  <div class="container">
    <h2>Customer Search</h2>
    <p class="subtitle">Search by customer ID, name, or account number.</p>
    <form method="GET" action="/customers/search" id="search-form">
      <div class="search-bar">
        <input type="text" name="q" id="search-input" value="<%= q %>" placeholder="Enter customer ID, name or account number..." autocomplete="off">
        <button type="submit" class="btn" id="search-btn">Search</button>
      </div>
    </form>
    <% if (q && results.length === 0) { %>
      <div class="no-results" id="no-results">No customers found matching "<strong><%= q %></strong>".</div>
    <% } else if (results.length > 0) { %>
      <table id="results-table">
        <thead>
          <tr>
            <th>Customer ID</th>
            <th>Name</th>
            <th>Account</th>
            <th>Segment</th>
            <th>Branch</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% results.forEach(c => { %>
          <tr class="result-row">
            <td class="col-id"><%= c.id %></td>
            <td class="col-name"><%= c.name %></td>
            <td class="col-account"><%= c.account %></td>
            <td><%= c.segment %></td>
            <td><%= c.branch %></td>
            <td><span class="badge badge-<%= c.status.toLowerCase() %>"><%= c.status %></span></td>
            <td><a href="/customers/<%= c.id %>" class="btn" style="padding:5px 12px;font-size:12px;">View</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>

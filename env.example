# Environment variables — copy to .env and fill in for local dev
# DO NOT commit .env to source control

# CRM credentials (used by mock-crm + rpa service)
CRM_USER=admin
CRM_PASS=demo123!@#$

# n8n admin credentials
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=n8npass!@#$

# n8n encryption key (generate a random string for production)
N8N_ENCRYPTION_KEY=changeme-encryption-key!@#$

# JWT secret used to sign/verify mobile app tokens
JWT_SECRET=changeme-jwt-secret!@#$

# Public hostname (set to Fly.io domain for hosted deployments)
N8N_HOST=localhost

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f4f6f9; color: #333; }
    nav { background: #1a2744; padding: 0 24px; display: flex; align-items: center; height: 52px; }
    nav .brand { color: #fff; font-weight: bold; font-size: 16px; margin-right: 32px; }
    nav a { color: #aabbd4; text-decoration: none; font-size: 13px; margin-right: 20px; padding: 4px 0; }
    nav a:hover, nav a.active { color: #fff; border-bottom: 2px solid #4a9fd4; }
    nav .user-info { margin-left: auto; color: #aabbd4; font-size: 12px; }
    nav .user-info a { color: #e8a87c; }
    .container { max-width: 1000px; margin: 32px auto; padding: 0 16px; }
    h2 { font-size: 20px; margin-bottom: 6px; color: #1a2744; }
    .subtitle { color: #666; font-size: 14px; margin-bottom: 24px; }
    .cards { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 24px; }
    .card { background: #fff; border: 1px solid #dde3ed; border-radius: 4px; padding: 24px; flex: 1; min-width: 220px; }
    .card-icon { font-size: 28px; margin-bottom: 10px; }
    .card-title { font-weight: bold; font-size: 15px; margin-bottom: 6px; }
    .card-desc { color: #666; font-size: 13px; margin-bottom: 16px; }
    .btn { display: inline-block; background: #1a2744; color: #fff; padding: 8px 16px; border-radius: 3px; text-decoration: none; font-size: 13px; border: none; cursor: pointer; }
    .btn:hover { background: #243a6b; }
    .btn-outline { background: transparent; color: #1a2744; border: 1px solid #1a2744; }
    .btn-outline:hover { background: #1a2744; color: #fff; }
    .notice { background: #fff8e1; border: 1px solid #f0c040; border-radius: 3px; padding: 10px 14px; font-size: 12px; color: #7a5c00; }
    .search-bar { display: flex; gap: 10px; margin-bottom: 24px; }
    .search-bar input { flex: 1; padding: 10px 14px; border: 1px solid #ccd2de; border-radius: 3px; font-size: 14px; }
    .search-bar input:focus { outline: none; border-color: #1a2744; }
    table { width: 100%; background: #fff; border-collapse: collapse; border: 1px solid #dde3ed; border-radius: 4px; overflow: hidden; }
    th { background: #1a2744; color: #fff; padding: 10px 14px; text-align: left; font-size: 12px; font-weight: bold; letter-spacing: 0.5px; }
    td { padding: 10px 14px; font-size: 13px; border-bottom: 1px solid #eef0f4; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8f9fc; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 11px; font-weight: bold; }
    .badge-active { background: #d4edda; color: #155724; }
    .badge-inactive { background: #f8d7da; color: #721c24; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 12px; font-weight: bold; color: #555; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 9px 12px; border: 1px solid #ccd2de; border-radius: 3px; font-size: 14px; }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus { outline: none; border-color: #1a2744; }
    .form-group textarea { min-height: 80px; resize: vertical; }
    .form-row { display: flex; gap: 16px; }
    .form-row .form-group { flex: 1; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; background: #fff; border: 1px solid #dde3ed; border-radius: 4px; padding: 24px; margin-bottom: 20px; }
    .detail-field label { font-size: 11px; font-weight: bold; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }
    .detail-field span { display: block; font-size: 15px; color: #222; margin-top: 3px; }
    .alert-success { background: #d4edda; border: 1px solid #c3e6cb; color: #155724; padding: 10px 14px; border-radius: 3px; margin-bottom: 16px; font-size: 13px; }
    .alert-error { background: #fdecea; border: 1px solid #f5c6cb; color: #721c24; padding: 10px 14px; border-radius: 3px; margin-bottom: 16px; font-size: 13px; }
    .page-actions { display: flex; gap: 10px; margin-bottom: 20px; }
    .back-link { color: #1a2744; font-size: 13px; text-decoration: none; margin-bottom: 12px; display: inline-block; }
    .back-link:hover { text-decoration: underline; }
    .no-results { text-align: center; padding: 40px; color: #888; font-size: 14px; }
    .history-table { background: #fff; border: 1px solid #dde3ed; border-radius: 4px; overflow: hidden; }
  </style>
